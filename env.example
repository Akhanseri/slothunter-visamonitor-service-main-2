# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=visa_monitor

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Visa API
VISA_BASE_URL=https://ais.usvisa-info.com
VISA_DEBUG=0

# Visa Resident Credentials
VISA_RESIDENT_EMAIL=kairatbermukhanov@gmail.com
VISA_RESIDENT_PASSWORD=kairat951

# Visa No Resident Credentials
VISA_NO_RESIDENT_EMAIL=your-no-resident@email.com
VISA_NO_RESIDENT_PASSWORD=your-no-resident-password

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Telegram Topics (для форумов/супергрупп)
# Парсер запускается/завершается
TELEGRAM_TOPIC_PARSER=169887
# Ошибки парсера
TELEGRAM_TOPIC_ERRORS=170598
# Успешные парсинги и найденные слоты
TELEGRAM_TOPIC_SLOTS=171437
# Успешная/неуспешная запись
TELEGRAM_TOPIC_BOOKINGS=3

# Debug
DEBUG_VISA_RUNNER=0

# Logging
# Уровни логирования: error, warn, log, debug, verbose
# По умолчанию: error,warn,log (без debug и verbose для чистоты логов)
LOG_LEVEL=error,warn,log

# WhatsApp Service
WHATSAPP_SERVICE_URL=https://w-api.tegin.kz/queues/push
WHATSAPP_SERVICE_TOKEN=your-whatsapp-service-token

# Google Sheets
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_SHEETS_KEY_PATH=./dist/config/gsheet-key.json

# Server
PORT=8989
NODE_ENV=development

# Proxy (для обхода блокировки IP)
# Формат: http://username:password@proxy-host:port
# Если пароль содержит спецсимволы (+, @, #, % и т.д.) — закодируйте их в URL
# Пример рабочего прокси от DataImpulse:
# PROXY_URL=http://a86f7d1dcf5eb6a46903:46cfc7c210c0cb31@gw.dataimpulse.com:823
PROXY_URL=