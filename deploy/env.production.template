# Production Environment Variables для Visa Monitor
# 
# ИНСТРУКЦИЯ:
# 1. Скопируйте этот файл как .env.production
# 2. Заполните все значения реальными данными
# 3. НЕ коммитьте .env.production в git!
#

# ==================== БАЗА ДАННЫХ ====================
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
# TODO: ЗАМЕНИТЕ на безопасный пароль для production
DB_PASSWORD=your_secure_postgres_password_here
DB_DATABASE=visa_monitor

# ==================== TELEGRAM ====================
# TODO: ЗАМЕНИТЕ на реальные данные
# Получить токен: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Получить chat_id: https://t.me/userinfobot
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ==================== DOCKER HUB ====================
# TODO: ЗАМЕНИТЕ на ваш Docker Hub username
DOCKER_HUB_USERNAME=your_dockerhub_username

# Тег версии образов (обычно передается через deploy.sh)
IMAGE_TAG=latest

# ==================== PROXY (для обхода CloudFlare) ====================
# TODO: ЗАМЕНИТЕ на ваш proxy URL
# Формат: http://username:password@proxy-host:port
# Или: http://proxy-host:port (если без авторизации)
# Используется ТОЛЬКО для /users/sign_in запросов
# Пример прокси от DataImpulse:
# PROXY_URL=http://a86f7d1dcf5eb6a46903:46cfc7c210c0cb31@gw.dataimpulse.com:823
PROXY_URL=

# ==================== ОПЦИОНАЛЬНЫЕ ====================
# JWT Secret (если используется аутентификация)
# JWT_SECRET=your_jwt_secret_here

# Node Environment
NODE_ENV=production

# API Service Port
# PORT=8989

# Parser Types (resident, non-resident, all, disabled)
# PARSER_TYPE=all

